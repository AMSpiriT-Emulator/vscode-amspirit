{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "Amstrad CPC BASIC",
  "scopeName": "source.amstrad-basic",
  "patterns": [
    { "include": "#line-number" },
    { "include": "#comment" },
    { "include": "#string" },
    { "include": "#keyword-control" },
    { "include": "#keyword-statement" },
    { "include": "#function-builtin" },
    { "include": "#operator-logical" },
    { "include": "#number" },
    { "include": "#operator" },
    { "include": "#variable-string" },
    { "include": "#variable-integer" }
  ],
  "repository": {
    "line-number": {
      "match": "^[ \\t]*\\d+",
      "name": "entity.name.section.amstrad-basic"
    },
    "comment": {
      "patterns": [
        {
          "match": "(?i)\\b(REM)\\b(.*)",
          "captures": {
            "1": { "name": "keyword.other.rem.amstrad-basic" },
            "2": { "name": "comment.line.rem.amstrad-basic" }
          }
        },
        {
          "match": "'.*",
          "name": "comment.line.apostrophe.amstrad-basic"
        }
      ]
    },
    "string": {
      "begin": "\"",
      "end": "\"",
      "name": "string.quoted.double.amstrad-basic"
    },
    "keyword-control": {
      "match": "(?i)\\b(CALL|ELSE|END|FOR|GOTO|GOSUB|IF|NEXT|ON|RESUME|RETURN|RUN|STEP|STOP|THEN|TO|WEND|WHILE)\\b",
      "name": "keyword.control.amstrad-basic"
    },
    "keyword-statement": {
      "match": "(?i)\\b(AUTO|BORDER|CAT|CHAIN|CLS|DATA|DEF FN|DEFINT|DEFREAL|DEFSTR|DELETE|DI|DIM|DRAW|DRAWR|EI|ENT|ENV|ERASE|ERROR|EVERY|INK|INPUT|KEY|LET|LINE|LIST|LOAD|MERGE|MODE|MOVE|MOVER|NEW|ON ERROR GOTO|OPENIN|OPENOUT|OUT|PAPER|PEN|PLOT|PLOTR|POKE|PRINT|RANDOMIZE|READ|RENUM|RESTORE|SAVE|SOUND|SPEED|SYMBOL|TROFF|TRON|USING|WAIT|WIDTH|WINDOW|WRITE|CLOSEIN|CLOSEOUT)\\b",
      "name": "keyword.other.statement.amstrad-basic"
    },
    "function-builtin": {
      "match": "(?i)\\b(ABS|ASC|ATN|BIN\\$|CHR\\$|CINT|COS|DEG|EOF|ERL|ERR|EXP|FIX|FRE|HEX\\$|HIMEM|INKEY\\$|INKEY|INP|INSTR|INT|JOY|LEFT\\$|LEN|LOG10|LOG|LOWER\\$|MAX|MEM|MID\\$|MIN|PEEK|PI|POS|RAD|REMAIN|RIGHT\\$|RND|ROUND|SGN|SIN|SIZE|SPACE\\$|SPC|SQ|SQR|STR\\$|STRING\\$|TAN|TIME|UPPER\\$|VAL|VPOS|XPOS|YPOS)\\b",
      "name": "support.function.builtin.amstrad-basic"
    },
    "operator-logical": {
      "match": "(?i)\\b(AND|MOD|NOT|OR|XOR)\\b",
      "name": "keyword.operator.logical.amstrad-basic"
    },
    "number": {
      "patterns": [
        {
          "match": "&[0-9A-Fa-f]+",
          "name": "constant.numeric.hex.amstrad-basic"
        },
        {
          "match": "\\b[0-9]+(\\.[0-9]+)?([eE][+-]?[0-9]+)?\\b",
          "name": "constant.numeric.amstrad-basic"
        }
      ]
    },
    "operator": {
      "match": "[+\\-*/^<>=]",
      "name": "keyword.operator.amstrad-basic"
    },
    "variable-string": {
      "match": "\\b[A-Za-z][A-Za-z0-9]*\\$",
      "name": "variable.other.string.amstrad-basic"
    },
    "variable-integer": {
      "match": "\\b[A-Za-z][A-Za-z0-9]*%",
      "name": "variable.other.integer.amstrad-basic"
    }
  }
}
