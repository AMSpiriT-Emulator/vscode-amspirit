{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "module": "commonjs",
    "moduleResolution": "node",
    "outDir": "./out",
    "rootDir": "./src",
    "lib": ["ES2022"],
    "composite": false,
    "declaration": false,
    "declarationMap": false,
    "tsBuildInfoFile": "./.tsbuildinfo"
  },
  "references": [{ "path": "../shared" }],
  "include": ["src/**/*"],
  "exclude": ["node_modules", "out", "tests"]
}
