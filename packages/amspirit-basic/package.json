{
  "name": "amspirit-basic",
  "displayName": "AMSpiriT BASIC",
  "description": "Amstrad CPC BASIC editor with direct emulator injection for AMSpiriT Lite",
  "version": "0.2.0",
  "publisher": "amspirit-emulator",
  "private": true,
  "license": "MIT",
  "icon": "icon.png",
  "repository": {
    "type": "git",
    "url": "https://github.com/AMSpiriT-emulator/vscode-amspirit"
  },
  "bugs": {
    "url": "https://github.com/AMSpiriT-emulator/vscode-amspirit/issues"
  },
  "homepage": "https://github.com/AMSpiriT-emulator/vscode-amspirit#readme",
  "engines": {
    "vscode": "^1.80.0"
  },
  "categories": [
    "Programming Languages",
    "Other"
  ],
  "keywords": [
    "amstrad",
    "cpc",
    "basic",
    "locomotive basic",
    "emulator",
    "z80"
  ],
  "main": "./out/extension.js",
  "activationEvents": [
    "onDebugResolve:amspirit-basic"
  ],
  "contributes": {
    "languages": [
      {
        "id": "amstrad-basic",
        "aliases": [
          "Amstrad CPC BASIC",
          "CPC BASIC"
        ],
        "extensions": [
          ".bas"
        ],
        "configuration": "./language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "amstrad-basic",
        "scopeName": "source.amstrad-basic",
        "path": "./syntaxes/amstrad-basic.tmLanguage.json"
      }
    ],
    "breakpoints": [
      {
        "language": "amstrad-basic"
      }
    ],
    "debuggers": [
      {
        "type": "amspirit-basic",
        "label": "AMSpiriT BASIC",
        "languages": [
          "amstrad-basic"
        ],
        "configurationAttributes": {
          "attach": {
            "properties": {
              "host": {
                "type": "string",
                "description": "Host of the emulator web debug server.",
                "default": "127.0.0.1"
              },
              "port": {
                "type": "number",
                "description": "Port of the emulator web debug server (matches amspirit.webPort).",
                "default": 8765
              },
              "stopOnEntry": {
                "type": "boolean",
                "description": "Pause the emulator as soon as the debugger attaches.",
                "default": false
              }
            }
          },
          "launch": {
            "required": [
              "program"
            ],
            "properties": {
              "program": {
                "type": "string",
                "description": "Path to the .bas file to inject before debugging.",
                "default": "${file}"
              },
              "host": {
                "type": "string",
                "default": "127.0.0.1"
              },
              "port": {
                "type": "number",
                "default": 8765
              },
              "stopOnEntry": {
                "type": "boolean",
                "default": true
              }
            }
          }
        },
        "initialConfigurations": [
          {
            "type": "amspirit-basic",
            "request": "attach",
            "name": "Attach to AMSpiriT",
            "port": 8765
          }
        ],
        "configurationSnippets": [
          {
            "label": "AMSpiriT BASIC: Attach",
            "description": "Debug a BASIC program in a running AMSpiriT emulator.",
            "body": {
              "type": "amspirit-basic",
              "request": "attach",
              "name": "Attach to AMSpiriT",
              "port": 8765
            }
          },
          {
            "label": "AMSpiriT BASIC: Launch (inject current file)",
            "description": "Inject the current .bas, run it, and attach the debugger.",
            "body": {
              "type": "amspirit-basic",
              "request": "launch",
              "name": "Launch current BASIC",
              "program": "^\"\\${file}\"",
              "stopOnEntry": true
            }
          }
        ]
      }
    ],
    "commands": [
      {
        "command": "amspirit.launch",
        "title": "Launch Emulator",
        "category": "AMSpiriT",
        "icon": "$(play)"
      },
      {
        "command": "amspirit.connect",
        "title": "Connect to Emulator",
        "category": "AMSpiriT",
        "icon": "$(plug)"
      },
      {
        "command": "amspirit.inject",
        "title": "Inject BASIC (no run)",
        "category": "AMSpiriT",
        "icon": "$(arrow-right)"
      },
      {
        "command": "amspirit.pull",
        "title": "Pull BASIC from Emulator",
        "category": "AMSpiriT",
        "icon": "$(arrow-down)"
      },
      {
        "command": "amspirit.injectAndRun",
        "title": "Inject & Run BASIC",
        "category": "AMSpiriT",
        "icon": "$(run)"
      },
      {
        "command": "amspirit.resetAndInject",
        "title": "Reset & Inject BASIC (no run)",
        "category": "AMSpiriT",
        "icon": "$(debug-restart)"
      },
      {
        "command": "amspirit.resetAndRun",
        "title": "Reset & Run BASIC",
        "category": "AMSpiriT",
        "icon": "$(debug-rerun)"
      },
      {
        "command": "amspirit.openDocs",
        "title": "Open Documentation",
        "category": "AMSpiriT",
        "icon": "$(book)"
      },
      {
        "command": "amspirit.openSettings",
        "title": "Open Settings",
        "category": "AMSpiriT",
        "icon": "$(gear)"
      },
      {
        "command": "amspirit.openWalkthrough",
        "title": "Get Started",
        "category": "AMSpiriT",
        "icon": "$(book)"
      }
    ],
    "keybindings": [
      {
        "command": "amspirit.injectAndRun",
        "key": "f6",
        "when": "resourceLangId == amstrad-basic"
      },
      {
        "command": "amspirit.resetAndRun",
        "key": "shift+f6",
        "when": "resourceLangId == amstrad-basic"
      },
      {
        "command": "amspirit.inject",
        "key": "ctrl+f6",
        "when": "resourceLangId == amstrad-basic"
      }
    ],
    "menus": {
      "editor/title/run": [
        {
          "command": "amspirit.injectAndRun",
          "when": "resourceLangId == amstrad-basic",
          "group": "navigation@1"
        },
        {
          "command": "amspirit.resetAndRun",
          "when": "resourceLangId == amstrad-basic",
          "group": "navigation@2"
        },
        {
          "command": "amspirit.inject",
          "when": "resourceLangId == amstrad-basic",
          "group": "navigation@3"
        },
        {
          "command": "amspirit.pull",
          "when": "resourceLangId == amstrad-basic",
          "group": "navigation@4"
        }
      ],
      "commandPalette": [
        {
          "command": "amspirit.inject",
          "when": "editorLangId == amstrad-basic"
        },
        {
          "command": "amspirit.injectAndRun",
          "when": "editorLangId == amstrad-basic"
        },
        {
          "command": "amspirit.resetAndInject",
          "when": "editorLangId == amstrad-basic"
        },
        {
          "command": "amspirit.resetAndRun",
          "when": "editorLangId == amstrad-basic"
        }
      ]
    },
    "walkthroughs": [
      {
        "id": "amspirit.getStarted",
        "title": "Get started with AMSpiriT BASIC",
        "description": "Configure the emulator and inject your first Locomotive BASIC program.",
        "steps": [
          {
            "id": "amspirit.setBinary",
            "title": "Locate the AMSpiriT emulator",
            "description": "Tell the extension where your ``amspirit-lite`` binary lives — any build that exposes the web debug server works (SDL or Qt today).\n[Open Settings](command:amspirit.openSettings)",
            "media": {
              "markdown": "media/walkthrough/binary.md"
            },
            "completionEvents": [
              "onSettingChanged:amspirit.emulatorPath"
            ]
          },
          {
            "id": "amspirit.launchEmulator",
            "title": "Launch the emulator",
            "description": "Start AMSpiriT from VS Code. The status bar turns green when the extension can reach it.\n[Launch Emulator](command:amspirit.launch)",
            "media": {
              "markdown": "media/walkthrough/launch.md"
            },
            "completionEvents": [
              "onCommand:amspirit.launch"
            ]
          },
          {
            "id": "amspirit.firstInject",
            "title": "Inject your first BASIC program",
            "description": "Open a ``.bas`` file and press ``F6`` to inject and run it.\n[Inject & Run (F6)](command:amspirit.injectAndRun)",
            "media": {
              "markdown": "media/walkthrough/inject.md"
            },
            "completionEvents": [
              "onCommand:amspirit.injectAndRun"
            ]
          },
          {
            "id": "amspirit.readDocs",
            "title": "Read the documentation",
            "description": "Explore every command and setting in the full documentation.\n[Open Documentation](command:amspirit.openDocs)",
            "media": {
              "markdown": "media/walkthrough/docs.md"
            },
            "completionEvents": [
              "onCommand:amspirit.openDocs"
            ]
          }
        ]
      }
    ],
    "configuration": {
      "title": "AMSpiriT",
      "properties": {
        "amspirit.emulatorPath": {
          "type": "string",
          "default": "",
          "scope": "machine",
          "order": 1,
          "markdownDescription": "Absolute path to the AMSpiriT Lite binary. Any build that exposes the web debug server works — currently the SDL (`amspirit-lite-sdl`) and Qt (`amspirit-lite-qt`) desktop builds. Leave empty to be prompted on first launch.",
          "examples": [
            "/usr/local/bin/amspirit-lite-sdl",
            "/Applications/amspirit-lite-qt.app/Contents/MacOS/amspirit-lite-qt",
            "C:\\\\Tools\\\\amspirit-lite-sdl.exe"
          ]
        },
        "amspirit.webPort": {
          "type": "integer",
          "default": 8765,
          "minimum": 1,
          "maximum": 65535,
          "order": 2,
          "markdownDescription": "TCP port used by the emulator's web debug server. Must match the `--web-port` value passed at launch."
        },
        "amspirit.autoLaunch": {
          "type": "boolean",
          "default": false,
          "order": 3,
          "markdownDescription": "When `true`, automatically launch the emulator at activation if it is not already reachable."
        },
        "amspirit.emulatorArgs": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": [],
          "order": 4,
          "markdownDescription": "Extra command-line arguments appended after `--web-server --web-port <port>` when launching the emulator.",
          "examples": [
            [
              "--fullscreen"
            ],
            [
              "--scale",
              "2"
            ]
          ]
        }
      }
    }
  },
  "scripts": {
    "build": "node esbuild.mjs --production",
    "compile": "node esbuild.mjs",
    "watch": "node esbuild.mjs --watch",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "vscode:prepublish": "pnpm build",
    "package": "vsce package --no-dependencies",
    "publish:vsce": "vsce publish --no-dependencies --packagePath",
    "publish:ovsx": "ovsx publish",
    "clean": "rm -rf out *.tsbuildinfo",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@amspirit/shared": "workspace:*",
    "@vscode/debugadapter": "^1.68.0",
    "@vscode/debugprotocol": "^1.68.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/vscode": "^1.80.0",
    "@vitest/coverage-v8": "^4.1.8",
    "@vscode/vsce": "^3.9.2",
    "esbuild": "^0.28.1",
    "ovsx": "^1.0.1",
    "typescript": "^5.6.0",
    "vite": "^7.3.5",
    "vitest": "^4.1.8"
  }
}
