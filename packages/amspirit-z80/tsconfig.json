{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "module": "node16",
    "moduleResolution": "node16",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "types": ["node", "vscode"],
    "jsx": "react-jsx",
    "noEmit": true,
    "composite": false,
    "declaration": false,
    "declarationMap": false,
    "rootDir": ".",
    "tsBuildInfoFile": "./typecheck.tsbuildinfo"
  },
  "references": [{ "path": "../shared/tsconfig.build.json" }],
  "include": ["src/**/*", "webview/**/*", "tests/**/*", "vitest.config.mts"],
  "exclude": ["node_modules", "out"]
}
