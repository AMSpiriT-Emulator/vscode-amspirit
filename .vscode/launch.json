{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Run amspirit-basic",
      "type": "extensionHost",
      "request": "launch",
      "args": [
        "--extensionDevelopmentPath=${workspaceFolder}/packages/amspirit-basic",
        "${workspaceFolder}/sandbox"
      ],
      "outFiles": ["${workspaceFolder}/packages/amspirit-basic/out/**/*.js"],
      "preLaunchTask": "build:amspirit-basic"
    }
  ]
}
