{
  "name": "vscode-amspirit",
  "private": true,
  "packageManager": "pnpm@10.11.0",
  "engines": {
    "node": ">=20",
    "pnpm": ">=10"
  },
  "scripts": {
    "build": "pnpm -r --if-present run build",
    "test": "pnpm -r --if-present run test",
    "typecheck": "pnpm -r --if-present run typecheck",
    "lint": "biome lint .",
    "format": "biome format --write .",
    "check": "biome check .",
    "check:fix": "biome check --write .",
    "precommit": "biome check . && pnpm -r --if-present run typecheck && pnpm -r --if-present run test",
    "prepare": "git config core.hooksPath .githooks || true",
    "clean": "pnpm -r --if-present run clean && rm -rf node_modules"
  },
  "devDependencies": {
    "@biomejs/biome": "1.9.4",
    "typescript": "^5.6.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": ["@biomejs/biome", "@vscode/vsce-sign", "keytar", "esbuild"]
  }
}
