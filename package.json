{
  "name": "vscode-amspirit",
  "private": true,
  "packageManager": "pnpm@10.11.0",
  "engines": {
    "node": ">=20",
    "pnpm": ">=10"
  },
  "scripts": {
    "build": "pnpm -r --if-present run build",
    "test": "pnpm -r --if-present run test",
    "test:coverage": "pnpm -r --if-present run test:coverage",
    "typecheck": "pnpm -r --if-present run typecheck",
    "lint": "biome lint .",
    "format": "biome format --write .",
    "check": "biome check .",
    "check:fix": "biome check --write .",
    "knip": "knip",
    "audit:prod": "pnpm audit --prod --audit-level=high",
    "precommit": "biome check . && pnpm typecheck && pnpm test:coverage && pnpm knip",
    "prepare": "git config core.hooksPath .githooks || true",
    "clean": "pnpm -r --if-present run clean && rm -rf node_modules"
  },
  "devDependencies": {
    "@biomejs/biome": "2.5.0",
    "knip": "^6.16.1",
    "typescript": "^5.6.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@biomejs/biome",
      "@vscode/vsce-sign",
      "keytar",
      "esbuild"
    ],
    "overrides": {
      "esbuild": ">=0.28.1"
    }
  }
}
