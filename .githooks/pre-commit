#!/bin/sh
# Pre-commit gate: lint/format, type-check (incl. tests) and unit tests.
# Wired via `git config core.hooksPath .githooks` (run automatically by the
# root `prepare` script on `pnpm install`).
set -e

echo "› pre-commit: biome check"
pnpm biome check .

echo "› pre-commit: typecheck (src + tests)"
pnpm -r --if-present run typecheck

echo "› pre-commit: tests"
pnpm -r --if-present run test

echo "✓ pre-commit passed"
